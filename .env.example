# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Path to your downloaded GCP OAuth client secret JSON (required)
# Download from: GCP Console → APIs & Services → Credentials → your Desktop OAuth client
GOOGLE_CLIENT_SECRET=client_secret.json

# Where to store the SQLite token database (optional, default: tokens.db in project root)
TOKEN_DB_PATH=tokens.db

# Where to stream the agent conversation log (optional, default: agent_log.jsonl)
AGENT_LOG_FILE=agent_log.jsonl
